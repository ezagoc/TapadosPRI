`Student`           = mean(student)            * 100,
`Religious`         = mean(religious)          * 100,
.groups = "drop"
) |>
pivot_longer(-era, names_to = "sector", values_to = "pct")
p7 <- ggplot(labor_sec2, aes(x = era, y = pct, fill = era)) +
